# Staged launch flags. Copy to `.env` for local overrides, and set these on the
# host (Vercel/Netlify/etc.) for the real site. Both are baked in at BUILD time,
# so changing them needs a redeploy.
#
# NOTE: this is obscurity, not security. Every tool ships in the JS bundle no
# matter what these say — the flags only control what is listed and reachable.

# Comma-separated tool slugs that are public right now. Add one per LinkedIn post.
# Valid slugs: dithering, anti-aliasing, low-res-video, character-flow,
#              style-flow, future-table
# Unset in a production build = nothing is listed (fails closed on purpose).
# Unset in dev = everything is listed.
VITE_RELEASED="dithering"

# The secret in the friends link: https://your-site.com/?key=<secret>
# Visiting it once unlocks every tool for that browser (persisted in
# localStorage). `?lock=1` clears it again.
VITE_UNLOCK_SECRET="backstage"
